# ─── API Keys ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ─── Polymarket CLI ─────────────────────────────────────────────
POLYMARKET_CLI_PATH=polymarket

# ─── Trading Mode ──────────────────────────────────────────────
# Set PAPER_MODE=true for paper trading validation (required for first 14 days)
PAPER_MODE=true
RISK_LEVEL=paper
TOTAL_CAPITAL_USDC=6300

# ─── Glint.trade ───────────────────────────────────────────────
ENABLE_GLINT=true
# Set GLINT_HEADLESS=false for first-time login (manual Google auth)
GLINT_HEADLESS=true
GLINT_DEBUG=false

# ─── Leaderboard ───────────────────────────────────────────────
LEADERBOARD_POLL_MS=300000
LEADERBOARD_TOP_N=20

# ─── Wallet Monitor ────────────────────────────────────────────
WALLET_POLL_MS=30000

# ─── Leader Rotation (Hysteresis) ──────────────────────────────
# Rotate only when challenger leads by >5% for >1 hour
ROTATION_MARGIN_PCT=5
ROTATION_MIN_DURATION_MS=3600000

# ─── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
