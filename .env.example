# ─── API Keys ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ─── AI Provider ──────────────────────────────────────────────
# groq = free cloud API (recommended), ollama = local inference
AI_PROVIDER=groq
GROQ_API_KEY=gsk_your_key_here
# GROQ_MODEL=llama-3.3-70b-versatile   # default
# OLLAMA_BASE_URL=http://localhost:11434 # only if AI_PROVIDER=ollama
# OLLAMA_MODEL=llama3.2                 # only if AI_PROVIDER=ollama

# ─── Polymarket CLI ─────────────────────────────────────────────
POLYMARKET_CLI_PATH=polymarket

# ─── Trading Mode ──────────────────────────────────────────────
# Set PAPER_MODE=true for paper trading validation (required for first 14 days)
PAPER_MODE=true
RISK_LEVEL=paper
TOTAL_CAPITAL_USDC=6300

# ─── Glint.trade ───────────────────────────────────────────────
ENABLE_GLINT=true
# Set GLINT_HEADLESS=false for first-time login (manual Google auth)
GLINT_HEADLESS=true
GLINT_DEBUG=false

# ─── Leaderboard ───────────────────────────────────────────────
LEADERBOARD_POLL_MS=300000
LEADERBOARD_TOP_N=20

# ─── Wallet Monitor ────────────────────────────────────────────
WALLET_POLL_MS=30000
# ENABLE_WS_MONITOR=false        # WebSocket mode (experimental, default off)

# ─── Leader Rotation (Hysteresis) ──────────────────────────────
# Rotate only when challenger leads by >5% for >1 hour
ROTATION_MARGIN_PCT=5
ROTATION_MIN_DURATION_MS=3600000

# ─── Confirmation Thresholds ──────────────────────────────────
# Rank-1: only veto if AI confidence >= this (default 0.85, was 0.70)
VETO_CONFIDENCE_THRESHOLD=0.85
# Rank 2-5: corroboration checks needed (default 1 of 3, was 2 of 3)
WATCHER_MIN_CORROBORATIONS=1
WATCHER_AI_MIN_CONFIDENCE=0.65
WATCHER_OUT_OF_SPECIALTY_CONFIDENCE=0.75
WATCHER_ORDERBOOK_THRESHOLD=0.55

# ─── Position Management ─────────────────────────────────────
# MAX_OPEN_POSITIONS=8            # Override risk preset (default from preset)
# RANK1_RESERVED_SLOTS=2          # Slots reserved for rank-1 leader
# ENABLE_EDGE_FLOOR=false         # Dead zone filter (default off)
# STALE_POSITION_DAYS=7           # Flag positions open > N days

# ─── Liquidity Check ─────────────────────────────────────────
ENABLE_LIQUIDITY_CHECK=true
MAX_SLIPPAGE_PCT=0.02

# ─── Hold to Resolution (Experimental) ───────────────────────
# ENABLE_HOLD_TO_RESOLUTION=false
# HOLD_ENTRY_THRESHOLD=0.35
# HOLD_CURRENT_THRESHOLD=0.60

# ─── Health Endpoint ─────────────────────────────────────────
# HEALTH_PORT=8080                       # HTTP health check port

# ─── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
